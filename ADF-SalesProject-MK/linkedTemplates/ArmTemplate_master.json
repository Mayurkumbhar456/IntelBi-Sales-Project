{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "ADF-SalesProject-MK"
		},
		"LS_ADB_SalesProject_MK_accessToken": {
			"type": "secureString",
			"metadata": "Secure string for 'accessToken' of 'LS_ADB_SalesProject_MK'"
		},
		"LS_ADLS_SalesProject_MK_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_ADLS_SalesProject_MK'"
		},
		"LS_BLOB_SalesProject_MK_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'LS_BLOB_SalesProject_MK'"
		},
		"LS_ADLS_SalesProject_MK_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlssalesprojectmk.dfs.core.windows.net/"
		},
		"LS_KV_SalesProject_MK_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://KV-SalesProject-MK.vault.azure.net/"
		},
		"LS_SQLDB_ASQL_Target_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sqlserver-salesproject-mk.database.windows.net"
		},
		"LS_SQLDB_ASQL_Target_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "ASQL-SalesProject-MK"
		},
		"LS_SQLDB_ASQL_Target_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sqladminmk"
		},
		"LS_SQLDB_SALES_Source_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sqlserver-salesproject-mk.database.windows.net"
		},
		"LS_SQLDB_SALES_Source_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "SALES"
		},
		"LS_SQLDB_SALES_Source_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sqladminmk"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "ADF-SalesProject-MK_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_ADB_SalesProject_MK_accessToken": {
						"value": "[parameters('LS_ADB_SalesProject_MK_accessToken')]"
					},
					"LS_ADLS_SalesProject_MK_accountKey": {
						"value": "[parameters('LS_ADLS_SalesProject_MK_accountKey')]"
					},
					"LS_BLOB_SalesProject_MK_connectionString": {
						"value": "[parameters('LS_BLOB_SalesProject_MK_connectionString')]"
					},
					"LS_ADLS_SalesProject_MK_properties_typeProperties_url": {
						"value": "[parameters('LS_ADLS_SalesProject_MK_properties_typeProperties_url')]"
					},
					"LS_KV_SalesProject_MK_properties_typeProperties_baseUrl": {
						"value": "[parameters('LS_KV_SalesProject_MK_properties_typeProperties_baseUrl')]"
					},
					"LS_SQLDB_ASQL_Target_properties_typeProperties_server": {
						"value": "[parameters('LS_SQLDB_ASQL_Target_properties_typeProperties_server')]"
					},
					"LS_SQLDB_ASQL_Target_properties_typeProperties_database": {
						"value": "[parameters('LS_SQLDB_ASQL_Target_properties_typeProperties_database')]"
					},
					"LS_SQLDB_ASQL_Target_properties_typeProperties_userName": {
						"value": "[parameters('LS_SQLDB_ASQL_Target_properties_typeProperties_userName')]"
					},
					"LS_SQLDB_SALES_Source_properties_typeProperties_server": {
						"value": "[parameters('LS_SQLDB_SALES_Source_properties_typeProperties_server')]"
					},
					"LS_SQLDB_SALES_Source_properties_typeProperties_database": {
						"value": "[parameters('LS_SQLDB_SALES_Source_properties_typeProperties_database')]"
					},
					"LS_SQLDB_SALES_Source_properties_typeProperties_userName": {
						"value": "[parameters('LS_SQLDB_SALES_Source_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}